{
  "name": "nassila",
  "version": "1.1.3",
  "productName": "Nassila",
  "description": "Nassila — verify references, ground claims, and export submit-ready bibliographies.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/ensure-icon.mjs && electron-vite dev",
    "build": "node scripts/ensure-icon.mjs && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir --win --x64",
    "build:win": "npm run build && electron-builder --win nsis --x64",
    "build:win:portable": "npm run build && electron-builder --win portable --x64",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "icon:raster": "node scripts/rasterize-icon.mjs",
    "skills:install": "node scripts/install-cursor-skills.mjs",
    "skills:install:antigravity": "node scripts/install-antigravity-skills.mjs"
  },
  "keywords": [
    "citations",
    "references",
    "bibliography",
    "csl",
    "academic",
    "formatting"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "rcedit": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "to-ico": "^1.1.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@citation-js/plugin-ris": "^0.7.21",
    "@electron-toolkit/utils": "^4.0.0",
    "citeproc": "^2.4.63",
    "i18next": "^26.1.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.7",
    "zustand": "^5.0.12"
  }
}
